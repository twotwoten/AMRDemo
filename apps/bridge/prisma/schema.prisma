generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
  interface            = "asyncio"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Map {
  id         String   @id @default(cuid())
  name       String   @unique
  pgmPath    String
  yamlPath   String
  thumbnail  String?
  resolution Float
  width      Int
  height     Int
  originX    Float
  originY    Float
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())

  landmarks  Landmark[]
}

model Landmark {
  id        String   @id @default(cuid())
  mapId     String
  map       Map      @relation(fields: [mapId], references: [id])
  name      String
  x         Float
  y         Float
  theta     Float
  icon      String?
  createdAt DateTime @default(now())

  @@unique([mapId, name])
}
